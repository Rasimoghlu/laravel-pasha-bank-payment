{
    "name": "sarkhanrasimoghlu/laravel-pasha-bank-payment",
    "description": "Laravel package for Pasha Bank ECOMM payment integration",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "pasha-bank", "payment", "ecomm", "azerbaijan"],
    "authors": [
        {
            "name": "Sarkhan Rasimoglu",
            "email": "sarkhan@example.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Sarkhanrasimoghlu\\PashaBank\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sarkhanrasimoghlu\\PashaBank\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sarkhanrasimoghlu\\PashaBank\\PashaBankServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
